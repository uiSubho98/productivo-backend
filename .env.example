# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/productivity_app

# JWT
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=7d

# Google Drive Storage (optional - create a folder in GDrive, use its ID)
GDRIVE_ROOT_FOLDER_ID=

# Brevo (Sendinblue) Email
BREVO_API_KEY=your_brevo_api_key_here
BREVO_SENDER_EMAIL=noreply@yourapp.com
BREVO_SENDER_NAME=Productivity App

# Message Central (legacy — replaced by WhatsApp Cloud API below)
MESSAGE_CENTRAL_AUTH_TOKEN=your_message_central_auth_token_here
MESSAGE_CENTRAL_BASE_URL=https://cpaas.messagecentral.com

# ── WhatsApp Cloud API (Meta Business Platform) ──────────────────
# App credentials (from developers.facebook.com → your app)
WA_APP_ID=your_whatsapp_app_id_here
WA_APP_SECRET=your_app_secret_here

# From your WhatsApp Business Account → Phone Numbers → Phone Number ID
WA_PHONE_NUMBER_ID=your_phone_number_id_here

# Long-lived access token (System User token recommended for production)
# To get a long-lived token from a short-lived one, call:
#   POST /api/v1/whatsapp/token/exchange  { "shortLivedToken": "..." }
WA_ACCESS_TOKEN=your_long_lived_access_token_here

# A random secret you choose — must match what you set in Meta webhook config
WA_WEBHOOK_VERIFY_TOKEN=my_webhook_secret_123

# Graph API version
WA_API_VERSION=v19.0

# Business-initiated message limit per day (Tier 1 default: 250)
WA_DAILY_LIMIT=250

# ── WABridge (outbound template sends — invoice/task/meeting addons) ──
WABRIDGE_APP_KEY=your_wabridge_app_key
WABRIDGE_AUTH_KEY=your_wabridge_auth_key
WABRIDGE_DEVICE_ID=your_wabridge_device_id
WABRIDGE_BASE_URL=https://web.wabridge.com/api
WABRIDGE_TEMPLATE_INVOICE=831092433353192
WABRIDGE_TEMPLATE_TASK_REMINDER=
WABRIDGE_TEMPLATE_MEETING_INVITE=

# Frontend origin (for Socket.io CORS in production)
CLIENT_ORIGIN=http://localhost:5173

# Google APIs (Calendar + Meet)
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:5000/api/v1/auth/google/callback
GOOGLE_REFRESH_TOKEN=your_google_refresh_token_here

# File Upload
MAX_FILE_SIZE_MB=10

# ── Cashfree Payment Gateway ──────────────────────────────────────
# Test:  base=https://sandbox.cashfree.com/pg  ·  APP_ID starts with TEST
# Prod:  base=https://api.cashfree.com/pg      ·  APP_ID starts with a digit
CASHFREE_APP_ID=your_cashfree_app_id
CASHFREE_SECRET_KEY=your_cashfree_secret_key
CASHFREE_BASE_URL=https://sandbox.cashfree.com/pg
CASHFREE_API_VERSION=2022-09-01
